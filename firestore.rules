rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function matchHasUser(matchId) {
      return isSignedIn() &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.userIds
              .hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);

      match /blocks/{blockedId} {
        allow read, write: if isOwner(userId);
      }

      match /likes_sent/{likedId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /matches/{matchId} {
      allow read: if isSignedIn() && resource.data.userIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && request.resource.data.userIds.hasAny([request.auth.uid]);
      allow update: if isSignedIn() && resource.data.userIds.hasAny([request.auth.uid]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if matchHasUser(matchId);
        allow create: if matchHasUser(matchId) &&
            request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}
